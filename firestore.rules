rules_version = '2';

// Copy-paste these into Firebase Console -> Firestore Database -> Rules -> Publish.
// Anyone with the page link can read/edit the one shared household document,
// so keep the link private (see DEPLOY.md step 5).
service cloud.firestore {
  match /databases/{database}/documents {
    match /households/home {
      allow read, write: if request.auth != null;
    }
  }
}
